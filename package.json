{
  "name": "@cogna8/openclaw-plugin",
  "version": "0.4.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["src", "openclaw.plugin.json", "README.md", "LICENSE"],
  "publishConfig": { "access": "public" },

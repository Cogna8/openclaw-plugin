    "test": "vitest run"
  },
  "peerDependencies": {
    "openclaw": "^2026.4.15"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "^2026.4.15",
    "typescript": "^5.6.0",
    "vitest": "^1.6.0"
  },
  "openclaw": {
    "extensions": ["./src/index.ts"],
    "compat": {
      "pluginApi": ">=2026.4.0",
      "minGatewayVersion": ">=2026.4.0"
